  <messages>
    <message id="320" name="PARAM_EXT_REQUEST_READ">
      <description>Request to read a parameter by id or index.</description>
      <field type="uint8_t" name="target_system">System ID.</field>
      <field type="uint8_t" name="target_component">Component ID.</field>
      <field type="char[16]" name="param_id">Parameter id.</field>
      <field type="int16_t" name="param_index" invalid="-1">Parameter index, or -1 to use param_id.</field>
    </message>

    <message id="321" name="PARAM_EXT_REQUEST_LIST">
      <description>Request all parameters from this component.</description>
      <field type="uint8_t" name="target_system">System ID.</field>
      <field type="uint8_t" name="target_component">Component ID.</field>
    </message>

    <message id="322" name="PARAM_EXT_VALUE">
      <description>Emit one extended parameter value.</description>
      <field type="char[16]" name="param_id">Parameter id.</field>
      <field type="char[128]" name="param_value">Parameter value.</field>
      <field type="uint8_t" name="param_type" enum="MAV_PARAM_EXT_TYPE">Parameter type.</field>
      <field type="uint16_t" name="param_count">Total number of parameters.</field>
      <field type="uint16_t" name="param_index">Index of this parameter.</field>
    </message>

    <message id="323" name="PARAM_EXT_SET">
      <description>Set one extended parameter value.</description>
      <field type="uint8_t" name="target_system">System ID.</field>
      <field type="uint8_t" name="target_component">Component ID.</field>
      <field type="char[16]" name="param_id">Parameter id.</field>
      <field type="char[128]" name="param_value">Parameter value.</field>
      <field type="uint8_t" name="param_type" enum="MAV_PARAM_EXT_TYPE">Parameter type.</field>
    </message>

    <message id="324" name="PARAM_EXT_ACK">
      <description>Response from PARAM_EXT_SET.</description>
      <field type="char[16]" name="param_id">Parameter id.</field>
      <field type="char[128]" name="param_value">Parameter value.</field>
      <field type="uint8_t" name="param_type" enum="MAV_PARAM_EXT_TYPE">Parameter type.</field>
      <field type="uint8_t" name="param_result" enum="PARAM_ACK">Result code.</field>
    </message>

    <message id="52000" name="RTLS_DEVICE_STATUS">
      <description>Periodic RTLS-Link device status for discovery and monitoring.</description>
      <field type="uint32_t" name="time_boot_ms" units="ms">Timestamp since boot.</field>
      <field type="uint32_t" name="flags" enum="RTLS_DEVICE_STATUS_FLAGS">Status flags.</field>
      <field type="uint16_t" name="avg_rate_chz" units="cHz">Average position update rate.</field>
      <field type="uint16_t" name="min_rate_chz" units="cHz">Minimum position update rate.</field>
      <field type="uint16_t" name="max_rate_chz" units="cHz">Maximum position update rate.</field>
      <field type="uint16_t" name="log_udp_port">UDP log port.</field>
      <field type="uint8_t" name="role" enum="RTLS_DEVICE_ROLE">RTLS role.</field>
      <field type="uint8_t" name="anchors_seen">Visible anchor count.</field>
      <field type="uint8_t" name="mavlink_target_system">Configured ArduPilot target system id.</field>
      <field type="uint8_t" name="log_level">Compiled log level.</field>
      <field type="uint8_t" name="dynamic_anchor_count">Number of valid dynamic anchor entries.</field>
      <field type="uint8_t[8]" name="dynamic_anchor_id">Dynamic anchor IDs.</field>
      <field type="int32_t[8]" name="dynamic_anchor_x_mm" units="mm">Dynamic anchor X positions.</field>
      <field type="int32_t[8]" name="dynamic_anchor_y_mm" units="mm">Dynamic anchor Y positions.</field>
      <field type="int32_t[8]" name="dynamic_anchor_z_mm" units="mm">Dynamic anchor Z positions.</field>
      <field type="uint8_t[4]" name="ip">Device IPv4 address.</field>
      <field type="uint8_t[6]" name="mac">WiFi MAC address.</field>
      <field type="char[16]" name="device_type">Device type string.</field>
      <field type="char[8]" name="short_addr">UWB short address string.</field>
      <field type="char[16]" name="firmware_version">Firmware version string.</field>
    </message>

    <message id="52001" name="RTLS_COMMAND">
      <description>RTLS-Link management command. Simple commands can be represented by command id; named commands use name.</description>
      <field type="uint32_t" name="request_id">Client request id used to match responses.</field>
      <field type="uint16_t" name="command" enum="RTLS_COMMAND">RTLS command id.</field>
      <field type="uint8_t" name="name_len">Valid bytes in name.</field>
      <field type="char[32]" name="name">Optional command argument.</field>
    </message>

    <message id="52002" name="RTLS_COMMAND_RESPONSE">
      <description>RTLS-Link management command response.</description>
      <field type="uint32_t" name="request_id">Client request id.</field>
      <field type="uint16_t" name="command" enum="RTLS_COMMAND">RTLS command id.</field>
      <field type="uint8_t" name="result" enum="RTLS_RESULT">Command result.</field>
      <field type="uint8_t" name="payload_type" enum="RTLS_PAYLOAD_TYPE">Payload encoding.</field>
      <field type="uint8_t" name="chunk_index">Zero-based payload chunk index.</field>
      <field type="uint8_t" name="chunk_count">Total payload chunks for this response.</field>
      <field type="uint8_t" name="payload_len">Valid bytes in payload.</field>
      <field type="uint8_t[220]" name="payload">Response payload.</field>
    </message>
  </messages>
</mavlink>
