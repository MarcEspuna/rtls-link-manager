      <entry value="16" name="RTLS_COMMAND_TDOA_ANCHOR_MODEL_COLLECT_START"/>
      <entry value="17" name="RTLS_COMMAND_TDOA_ANCHOR_MODEL_COLLECT_STATUS"/>
